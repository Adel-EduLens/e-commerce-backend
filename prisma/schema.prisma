generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  phone     String?
  role      String   @default("user")
  status    String   @default("active")
  reviews   Review[]
}

model Trader {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  name       String?
  password   String
  createdAt  DateTime    @default(now())
  phone      String?
  products   Product[]
  wholesales Wholesale[]
  role       String      @default("trader")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  phone     String?
  role      String   @default("admin")
}

model FrequentlyAskedQuestion {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
}

model Prize {
  id        String   @id @default(cuid())
  name      String
  weight    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpCenterVideo {
  id        String   @id @default(cuid())
  title     String
  category  String
  youtubeId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id         String      @id @default(cuid())
  name       String      @unique
  products   Product[]
  wholesales Wholesale[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float

  brand  String?
  rating Float   @default(0)

  images ProductImage[]
  sizes  ProductSize[]
  colors ProductColor[]

  reviews Review[]

  traderId Int
  trader   Trader @relation(fields: [traderId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id  String @id @default(cuid())
  url String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSize {
  id   String @id @default(cuid())
  size String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductColor {
  id    String @id @default(cuid())
  color String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Review {
  id String @id @default(cuid())

  rating  Int
  comment String? @db.Text

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Design {
  id        String @id @default(cuid())
  title     String
  imagePath String
  votes     Int    @default(0)
}

model Wholesale {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float
  minOrder    Int     @default(1)

  brand  String?
  rating Float   @default(0)

  images WholesaleImage[]
  sizes  WholesaleSize[]
  colors WholesaleColor[]

  traderId Int
  trader   Trader @relation(fields: [traderId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WholesaleImage {
  id  String @id @default(cuid())
  url String

  wholesaleId String
  wholesale   Wholesale @relation(fields: [wholesaleId], references: [id], onDelete: Cascade)
}

model WholesaleSize {
  id   String @id @default(cuid())
  size String

  wholesaleId String
  wholesale   Wholesale @relation(fields: [wholesaleId], references: [id], onDelete: Cascade)
}

model WholesaleColor {
  id    String @id @default(cuid())
  color String

  wholesaleId String
  wholesale   Wholesale @relation(fields: [wholesaleId], references: [id], onDelete: Cascade)
}
