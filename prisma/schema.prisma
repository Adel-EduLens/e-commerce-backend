generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ Enums ============

enum ProductType {
  SHOP
  RETAIL
  WHOLESALE
  BLANK
}

enum ImageDirection {
  FRONT
  BACK
  LEFT
  RIGHT
  TOP
  BOTTOM
}

// ============ Users & Auth ============

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  phone     String?
  role      String   @default("user")
  status    String   @default("active")

  reviews Review[]

  couponUsages CouponUsage[]
  orders       Order[]

  notifyMeSubscriptions NotifyMeSubscription[]

  notifications  UserNotification[]
  wishlists      Wishlist[]
  recentlyViewed RecentlyViewedProduct[]
  recommends     Recommend[]

  addresses       Address[]
  cart            Cart?
  retailOrders    RetailOrder[]
  wholesaleOrders WholesaleOrder[]

  influencerCouponUsages InfluencerCouponUsage[]
}

model Address {
  id String @id @default(cuid())

  country       String
  city          String
  area          String
  streetAddress String
  apartment     String?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trader {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  phone     String?
  address   String?
  products  Product[]
  coupons   Coupon[]
  role      String    @default("trader")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  phone     String?
  role      String   @default("admin")
}

// ============ Misc ============

model FrequentlyAskedQuestion {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
}

model NotifyMeSubscription {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
}

model UserNotification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String   @db.Text
  type      String   @default("restock")
  productId String?
  imageUrl  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Prize {
  id        String   @id @default(cuid())
  name      String
  weight    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpCenterVideo {
  id        String   @id @default(cuid())
  title     String
  category  String
  youtubeId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpCenterCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Design {
  id        String @id @default(cuid())
  title     String
  imagePath String
  votes     Int    @default(0)
}

model ShopBanner {
  id              String  @id @default(cuid())
  title           String
  description     String
  buttonText      String?
  buttonLink      String?
  image           String
  backgroundColor String  @default("#C1121F")
  isActive        Boolean @default(true)
  order           Int     @default(0)
  type            String  @default("shop")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Category ============

model Category {
  id           String    @id @default(cuid())
  name         String
  products     Product[]
  coupons      Coupon[]
  image        String?
  appearOnHome Boolean   @default(false)
  isWholesale  Boolean   @default(false)
  isRetail     Boolean   @default(false)
  isShop       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([name, isWholesale, isRetail, isShop])
  @@map("categories")
}

// ============ Collection ============

model Collection {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?  @db.Text
  image        String
  appearOnHome Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products Product[]
}

// ============ Unified Product ============

model Product {
  id          String  @id @default(cuid())
  name        String
  description String? @db.LongText
  sku         String  @unique

  // --- Pricing (per type, nullable for unused types) ---
  shopPrice      Float? // SHOP
  retailPrice    Float? // RETAIL
  wholesalePrice Float? // WHOLESALE
  blankPrice     Float? // BLANK

  // --- Stock ---
  stock Int @default(0)

  // --- SHOP-specific ---
  sizeguide       String?
  flashDealPrice  Float?
  flashDealEndsAt DateTime?
  isMustHave      Boolean   @default(false)
  isFlashDeals    Boolean   @default(false)

  // --- RETAIL-specific ---
  depositAmount      Float?
  securityDeposit    Float?
  termsAndConditions String? @db.Text
  privacyPolicy      String? @db.Text
  isFeatured         Boolean @default(false)

  // --- WHOLESALE-specific ---
  minOrder            Int     @default(1)
  isBestDeal          Boolean @default(false)
  isMostPopular       Boolean @default(false)
  isPremiumCollection Boolean @default(false)

  // --- BLANK-specific ---
  isActive  Boolean           @default(true)
  materials ProductMaterial[]

  // --- Shared ---
  rating Float @default(0)

  // --- Type Relations ---
  productTypes ProductTypeRelation[]

  // --- Sub-relations ---
  images ProductImage[]
  sizes  ProductSize[]
  colors ProductColor[]

  // --- Business Relations ---
  reviews Review[]
  coupons Coupon[]

  traderId Int
  trader   Trader @relation(fields: [traderId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  categories Category[]

  collections  Collection[]
  retailOrders RetailOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Join table: Product ↔ ProductType (many-to-many via explicit model)
model ProductTypeRelation {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      ProductType

  @@unique([productId, type])
}

// ============ Unified ProductMaterial (for BLANK) ============

model ProductMaterial {
  id        String   @id @default(cuid())
  material  String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([productId, material])
}

// ============ Unified ProductImage ============
// - color: for SHOP/RETAIL/WHOLESALE images grouped by color
// - direction: for BLANK images (FRONT/BACK/LEFT/RIGHT/TOP/BOTTOM)
// - colorId: optional link to ProductColor for BLANK per-color images

model ProductImage {
  id        String          @id @default(cuid())
  url       String
  color     String?
  direction ImageDirection?
  colorId   String?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============ Unified ProductColor ============
// - minOrder / stock: WHOLESALE-specific per-color fields
// - sizes: WHOLESALE nested sizes per color

model ProductColor {
  id       String @id @default(cuid())
  color    String
  minOrder Int    @default(1)
  stock    Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // WHOLESALE: sizes nested under a color
  sizes ProductSize[]
}

// ============ Unified ProductSize ============
// - productColorId: optional, for WHOLESALE (sizes nested under a color)

model ProductSize {
  id       String @id @default(cuid())
  size     String
  quantity Int    @default(0)
  color    String?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  productColorId String?
  productColor   ProductColor? @relation(fields: [productColorId], references: [id], onDelete: Cascade)
}

// ============ Unified Brand (absorbs RetailBrand) ============

model Brand {
  id   String @id @default(cuid())
  name String @unique

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Unified Review (absorbs RetailProductReview) ============

model Review {
  id String @id @default(cuid())

  rating  Int
  comment String? @db.Text

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

// ============ Coupons ============

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  discount   Float
  validUntil DateTime
  usageLimit Int?
  usedCount  Int      @default(0)

  traderId Int
  trader   Trader @relation(fields: [traderId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  usages   CouponUsage[]
  isActive Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt   DateTime @default(now())
}

// ============ Orders ============

model Order {
  id            String      @id @default(cuid())
  userId        Int
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  phone         String
  email         String
  country       String
  city          String
  area          String
  streetAddress String
  apartment     String
  mapAddress    String?
  latitude      String?
  longitude     String?
  subtotal      Float
  discount      Float
  shipping      Float
  total         Float
  couponCode    String?
  status        String      @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  paymentMethod String      @default("COD") // COD, CARD
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  influencerCouponUsage InfluencerCouponUsage?
  influencerCommissions InfluencerCommission[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  title     String
  price     Float
  quantity  Int
  size      String?
  color     String?
  imageSrc  String?
}

// RetailOrder now references the unified Product (String id)
model RetailOrder {
  id String @id @default(cuid())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  productPrice    Float
  depositAmount   Float
  securityDeposit Float

  depositPaid Boolean @default(false)
  paymentId   String?

  idCardImage String
  idVerified  Boolean @default(false)

  startDate  DateTime?
  endDate    DateTime?
  returnDate DateTime?

  status String @default("PENDING")
  // PENDING
  // APPROVED
  // ACTIVE
  // COMPLETED
  // CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WholesaleOrder {
  id            String               @id @default(cuid())
  userId        Int
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  phone         String
  email         String
  country       String
  city          String
  area          String
  streetAddress String
  apartment     String
  mapAddress    String?
  latitude      String?
  longitude     String?
  subtotal      Float
  discount      Float
  shipping      Float
  total         Float
  status        String               @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  paymentMethod String               @default("COD") // COD, CARD
  items         WholesaleOrderItem[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model WholesaleOrderItem {
  id               String         @id @default(cuid())
  wholesaleOrderId String
  wholesaleOrder   WholesaleOrder @relation(fields: [wholesaleOrderId], references: [id], onDelete: Cascade)
  productId        String // unified Product id
  title            String
  price            Float
  quantity         Int
  size             String?
  color            String?
  imageSrc         String?
}

// ============ Cart ============

model Cart {
  id        String     @id @default(cuid())
  userId    Int?       @unique
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId   String
  productType String @default("SHOP")

  title    String
  price    Float
  quantity Int     @default(1)
  size     String?
  color    String?
  imageSrc String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Wishlist & Recently Viewed ============

model Wishlist {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productType String // RETAIL, WHOLESALE, SHOP, BLANK
  productId   String
  createdAt   DateTime @default(now())

  @@unique([userId, productType, productId])
}

model RecentlyViewedProduct {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productType String // RETAIL, WHOLESALE, SHOP, BLANK
  productId   String
  viewedAt    DateTime @default(now())

  @@unique([userId, productType, productId])
}

// ============ Recommendations ============

model Recommend {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  categoryId String
  type       String
  timestamp  DateTime @default(now())

  @@unique([userId, productId, type])
  @@map("recommend")
}

// ============ Influencer System ============

model Influencer {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  phone     String?
  status    String   @default("active") // active, suspended
  role      String   @default("influencer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coupon            InfluencerCoupon?
  commissionRecords InfluencerCommission[]
  settlements       InfluencerSettlement[]
}

model InfluencerCoupon {
  id                String  @id @default(cuid())
  code              String  @unique
  discountPercent   Float
  commissionPercent Float
  isActive          Boolean @default(true)

  influencerId Int        @unique
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  usages InfluencerCouponUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfluencerCouponUsage {
  id String @id @default(cuid())

  couponId String
  coupon   InfluencerCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  orderTotal       Float
  discountAmount   Float
  commissionAmount Float

  usedAt DateTime @default(now())

  @@unique([couponId, userId])
}

model InfluencerCommission {
  id String @id @default(cuid())

  influencerId Int
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  orderTotal        Float
  commissionPercent Float
  commissionAmount  Float

  status String @default("PENDING") // PENDING, ELIGIBLE, SETTLED

  eligibleAt DateTime

  settlementId String?
  settlement   InfluencerSettlement? @relation(fields: [settlementId], references: [id])

  createdAt DateTime @default(now())
}

model InfluencerSettlement {
  id String @id @default(cuid())

  influencerId Int
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  totalAmount Float
  periodStart DateTime
  periodEnd   DateTime

  status String    @default("PENDING") // PENDING, PAID
  paidAt DateTime?

  commissions InfluencerCommission[]

  createdAt DateTime @default(now())
}
