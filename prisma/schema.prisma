generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  phone     String?
  role      String   @default("user")
  status    String   @default("active")

  reviews              Review[]
  retailProductRatings RetailProductRating[]
  couponUsages         CouponUsage[]
  orders               Order[]

  notifyMeSubscriptions NotifyMeSubscription[]

  notifications UserNotification[]
  wishlists     Wishlist[]
  recentlyViewed RecentlyViewedProduct[]
  recommends    Recommend[]

  addresses Address[]
  cart      Cart?
  retailOrders RetailOrder[]
}

model Address {
  id String @id @default(cuid())

  country       String
  city          String
  area          String
  streetAddress String
  apartment     String?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trader {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  name       String?
  password   String
  createdAt  DateTime    @default(now())
  phone      String?
  address    String?
  products   Product[]
  wholesales Wholesale[]
  coupons    Coupon[]
  role       String      @default("trader")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  phone     String?
  role      String   @default("admin")
}

model FrequentlyAskedQuestion {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
}

model NotifyMeSubscription {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
}

model UserNotification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String   @db.Text
  type      String   @default("restock")
  productId String?
  imageUrl  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Prize {
  id        String   @id @default(cuid())
  name      String
  weight    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpCenterVideo {
  id        String   @id @default(cuid())
  title     String
  category  String
  youtubeId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpCenterCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id         String      @id @default(cuid())
  name       String      @unique
  products   Product[]
  wholesales Wholesale[]
  coupons    Coupon[]
  image      String?
  appearOnHome   Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String? @db.LongText
  price       Float
  sizeguide   String?
  sku         String? @unique
  stock       Int     @default(0)

  rating Float @default(0)

  images ProductImage[]
  sizes  ProductSize[]
  colors ProductColor[]

  flashDealPrice  Float?
  flashDealEndsAt DateTime?

  isMustHave   Boolean @default(false)
  isFlashDeals Boolean @default(false)

  reviews Review[]
  coupons Coupon[]

  traderId Int
  trader   Trader @relation(fields: [traderId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id   String @id @default(cuid())
  name String @unique

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  color     String?
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSize {
  id       String  @id @default(cuid())
  size     String
  quantity Int     @default(0)
  color    String?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductColor {
  id    String @id @default(cuid())
  color String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Review {
  id String @id @default(cuid())

  rating  Int
  comment String? @db.Text

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Design {
  id        String @id @default(cuid())
  title     String
  imagePath String
  votes     Int    @default(0)
}

model Wholesale {
  id                  String  @id @default(cuid())
  name                String
  description         String?
  price               Float
  minOrder            Int     @default(1)
  isBestDeal          Boolean @default(false)
  isMostPopular       Boolean @default(false)
  isPremiumCollection Boolean @default(false)
  sku                 String? @unique
  stock               Int     @default(0)

  brand  String?
  rating Float   @default(0)

  images WholesaleImage[]

  traderId Int
  trader   Trader @relation(fields: [traderId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  wholesaleColors WholesaleColor[]
}

model WholesaleImage {
  id    String  @id @default(cuid())
  url   String
  color String?

  wholesaleId String
  wholesale   Wholesale @relation(fields: [wholesaleId], references: [id], onDelete: Cascade)
}



model WholesaleSize {
  id       String @id @default(cuid())
  size     String

  wholesaleColorId String
  wholesaleColor   WholesaleColor @relation(fields: [wholesaleColorId], references: [id], onDelete: Cascade)
}

model WholesaleColor {
  id       String @id @default(cuid())
  color    String
  minOrder Int    @default(1)
  stock    Int    @default(0)

  wholesaleId String
  wholesale   Wholesale @relation(fields: [wholesaleId], references: [id], onDelete: Cascade)

  sizes WholesaleSize[]
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  discount   Float
  validUntil DateTime
  usageLimit Int?
  usedCount  Int      @default(0)

  traderId Int
  trader   Trader @relation(fields: [traderId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  usages   CouponUsage[]
  isActive Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Retail Products ============

model RetailCategory {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  slug        String          @unique
  description String?         @db.Text
  imageUrl    String?
  isActive    Boolean         @default(true)
  products    RetailProduct[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model RetailProduct {
  id               Int                   @id @default(autoincrement())
  name             String
  slug             String                @unique
  description      String?               @db.Text
  shortDescription String?
  price            Float
  discountPrice    Float?
  stock            Int                   @default(0)
  sku              String?               @unique
  brand            String?
  isFeatured       Boolean               @default(false)
  isActive         Boolean               @default(true)
  categoryId       Int
  category         RetailCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images           RetailProductImage[]
  colors           RetailProductColor[]
  sizes            RetailProductSize[]
  ratings          RetailProductRating[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  depositAmount       Float
  securityDeposit     Float  
  termsAndConditions  String? @db.Text
  privacyPolicy       String? @db.Text

  retailOrders RetailOrder[]
}

model RetailProductImage {
  id        Int           @id @default(autoincrement())
  url       String
  alt       String?
  isMain    Boolean       @default(false)
  productId Int
  product   RetailProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RetailProductColor {
  id        Int           @id @default(autoincrement())
  name      String
  hexCode   String?
  productId Int
  product   RetailProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RetailProductSize {
  id        Int           @id @default(autoincrement())
  name      String
  stock     Int?
  productId Int
  product   RetailProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RetailProductRating {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  retailProductId Int
  retailProduct   RetailProduct @relation(fields: [retailProductId], references: [id], onDelete: Cascade)
  rating          Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([userId, retailProductId])
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt   DateTime @default(now())
}

model Order {
  id            String      @id @default(cuid())
  userId        Int
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  phone         String
  email         String
  country       String
  city          String
  area          String
  streetAddress String
  apartment     String
  mapAddress    String?
  latitude      String?
  longitude     String?
  subtotal      Float
  discount      Float
  shipping      Float
  total         Float
  couponCode    String?
  status        String      @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  paymentMethod String      @default("COD") // COD, CARD
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  title     String
  price     Float
  quantity  Int
  size      String?
  color     String?
  imageSrc  String?
}

model Wishlist {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productType String // RETAIL, WHOLESALE, SHOP
  productId   String
  createdAt   DateTime @default(now())

  @@unique([userId, productType, productId])
}

model RecentlyViewedProduct {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productType String // RETAIL, WHOLESALE, SHOP
  productId   String
  viewedAt    DateTime @default(now())

  @@unique([userId, productType, productId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    Int?       @unique
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  productId   String
  productType String   @default("RETAIL")
  
  title       String
  price       Float
  quantity    Int      @default(1)
  size        String?
  color       String?
  imageSrc    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Recommend {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  categoryId  String
  type        String
  timestamp   DateTime @default(now())

  @@unique([userId, productId, type])
  @@map("recommend")
}

model ShopBanner {
  id              String   @id @default(cuid())
  title           String
  description     String
  buttonText      String?
  buttonLink      String?
  image           String
  backgroundColor String   @default("#C1121F")
  isActive        Boolean  @default(true)
  order           Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlankProduct {
  id String @id @default(cuid())

  name String // T-Shirt, Hoodie, Pants

  description String? @db.LongText

  material String // Cotton, Polyester

  pattern String // Plain, Stripes, Printed

  price Float?

  isActive Boolean @default(true)

  colors BlankProductColor[]
  images BlankProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlankProductColor {
  id String @id @default(cuid())

  color String

  blankProductId String
  blankProduct BlankProduct @relation( fields: [blankProductId], references: [id], onDelete: Cascade )

  createdAt DateTime @default(now())
}

model BlankProductImage {
  id String @id @default(cuid())

  url String

  color String 

  blankProductId String
  blankProduct BlankProduct @relation( fields: [blankProductId], references: [id], onDelete: Cascade )
}

model RetailOrder {
  id String @id @default(cuid())

  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId Int
  product RetailProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  productPrice Float
  depositAmount Float
  securityDeposit Float

  depositPaid Boolean @default(false)
  paymentId String?

  idCardImage String
  idVerified Boolean @default(false)

  startDate DateTime?
  endDate DateTime?
  returnDate DateTime?

  status String @default("PENDING")
  // PENDING
  // APPROVED
  // ACTIVE
  // COMPLETED
  // CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeBanner {
  id        Int      @id @default(autoincrement())
  title     String
  image     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}